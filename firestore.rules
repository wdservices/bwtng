rules_version = '2'; 
service cloud.firestore { 
  match /databases/{database}/documents { 
    // Allow read access to anyone, but only authenticated users can write 
    match /tools/{toolId} { 
      allow read: if true; 
      allow create, update, delete: if request.auth != null; 
    } 
    
    // Blog security rules
    match /blogs/{blogId} { 
      allow read: if true; 
      allow create, update, delete: if request.auth != null; 
    } 
    
    // Default deny all other access 
    match /{document=**} { 
      allow read, write: if false; 
    } 
  } 
}
