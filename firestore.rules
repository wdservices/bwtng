rules_version = '2'; 
service cloud.firestore { 
  match /databases/{database}/documents { 
    // Tools collection - public read, auth write
    match /tools/{toolId} { 
      allow read: if true; 
      allow create, update, delete: if request.auth != null; 
    } 
    
    // Blogs collection - public read, auth write
    match /blogs/{blogId} { 
      allow read: if true; 
      allow create, update, delete: if request.auth != null; 
    } 
    
    // Cohorts collection - public read (for active cohort), auth write
    match /cohorts/{cohortId} { 
      allow read: if true; 
      allow create, update, delete: if request.auth != null; 
    } 
    
    // Registrations collection - public create (for registration form), auth read/list
    match /registrations/{registrationId} { 
      allow create: if true; 
      allow get, list: if request.auth != null; 
      allow update, delete: if false; // Prevent updates/deletes via client
    } 
    
    // Payments collection - public create (for payment verification), auth read/list
    match /payments/{paymentId} { 
      allow create: if true; 
      allow get, list: if request.auth != null; 
      allow update, delete: if false; // Prevent updates/deletes via client
    } 
    
    // Popup settings collection - public read, auth write
    match /popup_settings/{settingsId} { 
      allow read: if true; 
      allow create, update, delete: if request.auth != null; 
    } 
    
    // Default deny all other access 
    match /{document=**} { 
      allow read, write: if false; 
    } 
  }
}